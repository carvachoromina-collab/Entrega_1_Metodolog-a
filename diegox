from enum import Enum
from dataclasses import dataclass
from typing import Optional, List
from abc import ABC, abstractmethod


# ==========================================
# 1. DOMINIO: PEDIDO
# ==========================================

class EstadoPedido(Enum):
    CREADO = "Creado"
    VALIDADO = "Validado"
    PENDIENTE_ASIGNACION = "Pendiente de asignacion"
    ASIGNADO = "Asignado"
    EN_RUTA = "En ruta"
    INTENTO_FALLIDO = "Intento fallido"
    REPROGRAMADO = "Reprogramado"
    ENTREGADO = "Entregado"
    CANCELADO = "Cancelado"


@dataclass(frozen=True)
class Origen:
    id_punto_origen: str
    direccion_retiro: str
    es_interpretable: bool = True


@dataclass(frozen=True)
class Destino:
    direccion: str
    nombre_destinatario: str
    medio_contacto: str
    es_interpretable: bool = True


@dataclass(frozen=True)
class DetallesEntrega:
    tipo: str
    ventana_tiempo: Optional[str] = None


@dataclass(frozen=True)
class DetallesLogistica:
    tipo_carga: str
    peso_estimado: float


class Pedido:
    def __init__(
        self,
        id_pedido: str,
        canal_origen: str,
        origen: Origen,
        destino: Destino,
        entrega: DetallesEntrega,
        logistica: DetallesLogistica
    ):
        self.id_pedido = id_pedido
        self.canal_origen = canal_origen
        self.origen = origen
        self.destino = destino
        self.entrega = entrega
        self.logistica = logistica
        self.estado = EstadoPedido.CREADO

    def marcar_validado(self):
        self.estado = EstadoPedido.VALIDADO


# ==========================================
# 2. REGLAS DE VALIDACION
# ==========================================

class ReglaValidacion(ABC):
    @abstractmethod
    def es_valida(self, pedido: Pedido) -> bool:
        pass

    @abstractmethod
    def mensaje_error(self) -> str:
        pass


class ValidacionOrigen(ReglaValidacion):
    def es_valida(self, pedido: Pedido) -> bool:
        return (
            pedido.origen is not None
            and bool(pedido.origen.id_punto_origen)
            and bool(pedido.origen.direccion_retiro)
            and pedido.origen.es_interpretable
        )

    def mensaje_error(self) -> str:
        return "El origen no cumple con las condiciones minimas de validacion."


class ValidacionDestino(ReglaValidacion):
    def es_valida(self, pedido: Pedido) -> bool:
        return (
            pedido.destino is not None
            and bool(pedido.destino.direccion)
            and bool(pedido.destino.nombre_destinatario)
            and bool(pedido.destino.medio_contacto)
            and pedido.destino.es_interpretable
        )

    def mensaje_error(self) -> str:
        return "El destino no cumple con las condiciones minimas de validacion."


class ValidacionEntrega(ReglaValidacion):
    def es_valida(self, pedido: Pedido) -> bool:
        if pedido.entrega is None or not pedido.entrega.tipo:
            return False
        if pedido.entrega.tipo.lower() == "programada" and not pedido.entrega.ventana_tiempo:
            return False
        return True

    def mensaje_error(self) -> str:
        return "La informacion de entrega no es valida."


class ValidacionLogistica(ReglaValidacion):
    def es_valida(self, pedido: Pedido) -> bool:
        return (
            pedido.logistica is not None
            and bool(pedido.logistica.tipo_carga)
            and pedido.logistica.peso_estimado > 0
        )

    def mensaje_error(self) -> str:
        return "La informacion logistica no es valida."


class ValidacionIdentificacion(ReglaValidacion):
    def es_valida(self, pedido: Pedido) -> bool:
        return bool(pedido.id_pedido) and bool(pedido.canal_origen)

    def mensaje_error(self) -> str:
        return "Falta identificacion del pedido."


# ==========================================
# 3. SERVICIO DE VALIDACION
# ==========================================

class ValidadorPedido:
    def __init__(self, reglas: Optional[List[ReglaValidacion]] = None):
        self.reglas = reglas or [
            ValidacionOrigen(),
            ValidacionDestino(),
            ValidacionEntrega(),
            ValidacionLogistica(),
            ValidacionIdentificacion()
        ]

    def validar(self, pedido: Pedido) -> tuple[bool, str]:
        if pedido.estado in [EstadoPedido.ENTREGADO, EstadoPedido.CANCELADO]:
            return False, f"No se puede validar un pedido en estado {pedido.estado.value}."

        for regla in self.reglas:
            if not regla.es_valida(pedido):
                return False, regla.mensaje_error()

        pedido.marcar_validado()
        return True, "Pedido validado correctamente."


# ==========================================
# 4. BUILDER DE PEDIDO
# ==========================================

class PedidoBuilder:
    def __init__(self):
        self._id_pedido = None
        self._canal_origen = None
        self._origen = None
        self._destino = None
        self._entrega = None
        self._logistica = None

    def set_identificacion(self, id_pedido: str, canal_origen: str):
        self._id_pedido = id_pedido
        self._canal_origen = canal_origen
        return self

    def set_origen(self, id_punto_origen: str, direccion_retiro: str, es_interpretable: bool = True):
        self._origen = Origen(id_punto_origen, direccion_retiro, es_interpretable)
        return self

    def set_destino(
        self,
        direccion: str,
        nombre_destinatario: str,
        medio_contacto: str,
        es_interpretable: bool = True
    ):
        self._destino = Destino(direccion, nombre_destinatario, medio_contacto, es_interpretable)
        return self

    def set_entrega(self, tipo: str, ventana_tiempo: Optional[str] = None):
        self._entrega = DetallesEntrega(tipo, ventana_tiempo)
        return self

    def set_logistica(self, tipo_carga: str, peso_estimado: float):
        self._logistica = DetallesLogistica(tipo_carga, peso_estimado)
        return self

    def build(self) -> Pedido:
        return Pedido(
            id_pedido=self._id_pedido,
            canal_origen=self._canal_origen,
            origen=self._origen,
            destino=self._destino,
            entrega=self._entrega,
            logistica=self._logistica
        )

